{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pocitacpc-hub.github.io/TravelApp-PublishedTrips/schemas/published-trip.schema.json",
  "title": "TravelApp published trip",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "documentType", "publicId", "slug", "revision", "title", "subtitle", "summary", "dateFrom", "dateTo", "timezone", "countryCode", "locale", "currency", "status", "isListed", "generatedAt", "publishedAt", "location", "weather", "days", "places", "generalTips", "publicDocuments", "vault", "sources", "quality"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "documentType": { "const": "published_trip" },
    "publicId": { "type": "string", "format": "uuid" },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80 },
    "revision": { "type": "integer", "minimum": 1 },
    "title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "subtitle": { "type": ["string", "null"], "maxLength": 160 },
    "summary": { "type": ["string", "null"], "maxLength": 1000 },
    "dateFrom": { "type": "string", "format": "date" },
    "dateTo": { "type": "string", "format": "date" },
    "timezone": { "type": "string", "minLength": 3, "maxLength": 80 },
    "countryCode": { "type": "string", "pattern": "^[A-Z]{2}$" },
    "locale": { "type": "string", "pattern": "^[a-z]{2}-[A-Z]{2}$" },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "status": { "enum": ["upcoming", "active", "completed", "archived"] },
    "isListed": { "type": "boolean" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "publishedAt": { "type": "string", "format": "date-time" },
    "location": { "$ref": "#/$defs/location" },
    "weather": { "oneOf": [{ "$ref": "#/$defs/weather" }, { "type": "null" }] },
    "days": { "type": "array", "items": { "$ref": "#/$defs/day" }, "maxItems": 31 },
    "places": { "type": "array", "items": { "$ref": "#/$defs/place" }, "maxItems": 500 },
    "generalTips": { "type": "array", "items": { "type": "string", "maxLength": 500 }, "maxItems": 100 },
    "publicDocuments": { "type": "array", "maxItems": 50 },
    "vault": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "manifestUrl"],
      "properties": {
        "available": { "type": "boolean" },
        "manifestUrl": { "type": ["string", "null"], "maxLength": 200 }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "url"],
        "properties": {
          "title": { "type": "string", "maxLength": 200 },
          "url": { "type": "string", "format": "uri", "maxLength": 2000 }
        }
      },
      "maxItems": 500
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["warnings", "needsVerificationCount"],
      "properties": {
        "warnings": { "type": "array", "items": { "type": "string", "maxLength": 500 }, "maxItems": 100 },
        "needsVerificationCount": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "nullableText": { "type": ["string", "null"], "maxLength": 1000 },
    "mapLinks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["googleMapsUrl", "mapyUrl"],
      "properties": {
        "googleMapsUrl": { "type": ["string", "null"], "format": "uri", "maxLength": 2000 },
        "mapyUrl": { "type": ["string", "null"], "format": "uri", "maxLength": 2000 }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "region", "latitude", "longitude", "publicAccommodationArea", "exactAccommodationInVault"],
      "properties": {
        "name": { "type": "string", "maxLength": 120 },
        "region": { "$ref": "#/$defs/nullableText" },
        "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "publicAccommodationArea": { "$ref": "#/$defs/nullableText" },
        "exactAccommodationInVault": { "type": "boolean" }
      }
    },
    "weather": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "latitude", "longitude", "timezone"],
      "properties": {
        "enabled": { "type": "boolean" },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "timezone": { "type": "string", "maxLength": 80 }
      }
    },
    "alternative": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["title", "text"],
      "properties": {
        "title": { "type": "string", "maxLength": 160 },
        "text": { "type": "string", "maxLength": 1000 }
      }
    },
    "day": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publicId", "date", "dayIndex", "title", "summary", "dayType", "weatherNote", "alternatives", "items"],
      "properties": {
        "publicId": { "type": "string", "format": "uuid" },
        "date": { "type": "string", "format": "date" },
        "dayIndex": { "type": "integer", "minimum": 1 },
        "title": { "type": "string", "maxLength": 160 },
        "summary": { "$ref": "#/$defs/nullableText" },
        "dayType": { "type": "string", "maxLength": 40 },
        "weatherNote": { "$ref": "#/$defs/nullableText" },
        "alternatives": {
          "type": "object",
          "additionalProperties": false,
          "required": ["badWeather", "hotWeather", "easy", "active"],
          "properties": {
            "badWeather": { "$ref": "#/$defs/alternative" },
            "hotWeather": { "$ref": "#/$defs/alternative" },
            "easy": { "$ref": "#/$defs/alternative" },
            "active": { "$ref": "#/$defs/alternative" }
          }
        },
        "items": { "type": "array", "items": { "$ref": "#/$defs/item" }, "maxItems": 250 }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publicId", "type", "title", "startTime", "endTime", "durationMinutes", "status", "placePublicId", "transportMode", "cost", "notes", "needsVerification", "sourceUrl", "mapLinks", "tags"],
      "properties": {
        "publicId": { "type": "string", "format": "uuid" },
        "type": { "type": "string", "maxLength": 50 },
        "title": { "type": "string", "maxLength": 200 },
        "startTime": { "type": ["string", "null"], "pattern": "^(?:[01]\\d|2[0-3]):[0-5]\\d$" },
        "endTime": { "type": ["string", "null"], "pattern": "^(?:[01]\\d|2[0-3]):[0-5]\\d$" },
        "durationMinutes": { "type": ["integer", "null"], "minimum": 0, "maximum": 1440 },
        "status": { "enum": ["planned", "optional", "cancelled"] },
        "placePublicId": { "type": ["string", "null"], "format": "uuid" },
        "transportMode": { "type": ["string", "null"], "maxLength": 40 },
        "cost": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["amount", "currency", "text"],
          "properties": {
            "amount": { "type": ["number", "null"], "minimum": 0 },
            "currency": { "type": ["string", "null"], "pattern": "^[A-Z]{3}$" },
            "text": { "$ref": "#/$defs/nullableText" }
          }
        },
        "notes": { "$ref": "#/$defs/nullableText" },
        "needsVerification": { "type": "boolean" },
        "sourceUrl": { "type": ["string", "null"], "format": "uri", "maxLength": 2000 },
        "mapLinks": { "$ref": "#/$defs/mapLinks" },
        "tags": { "type": "array", "items": { "type": "string", "maxLength": 40 }, "maxItems": 30 }
      }
    },
    "place": {
      "type": "object",
      "additionalProperties": false,
      "required": ["publicId", "name", "category", "latitude", "longitude", "description", "whyVisit", "travelerTips", "officialUrl", "sourceUrl", "reservationUrl", "mapLinks", "needsVerification"],
      "properties": {
        "publicId": { "type": "string", "format": "uuid" },
        "name": { "type": "string", "maxLength": 200 },
        "category": { "type": "string", "maxLength": 60 },
        "latitude": { "type": ["number", "null"], "minimum": -90, "maximum": 90 },
        "longitude": { "type": ["number", "null"], "minimum": -180, "maximum": 180 },
        "description": { "$ref": "#/$defs/nullableText" },
        "whyVisit": { "$ref": "#/$defs/nullableText" },
        "travelerTips": { "$ref": "#/$defs/nullableText" },
        "officialUrl": { "type": ["string", "null"], "format": "uri", "maxLength": 2000 },
        "sourceUrl": { "type": ["string", "null"], "format": "uri", "maxLength": 2000 },
        "reservationUrl": { "type": ["string", "null"], "format": "uri", "maxLength": 2000 },
        "mapLinks": { "$ref": "#/$defs/mapLinks" },
        "needsVerification": { "type": "boolean" }
      }
    }
  }
}
