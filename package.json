{
  "name": "travelapp-published-trips",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx tools/prepare-public-content.ts && vite",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsx tools/prepare-public-content.ts && vite build && tsx tools/build-site.ts",
    "validate-content": "tsx tools/validate-content.ts",
    "security-lint": "tsx tools/security-lint.ts",
    "check": "npm run lint && npm run validate-content && npm run security-lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
